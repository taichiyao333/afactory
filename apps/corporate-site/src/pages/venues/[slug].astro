---
import { getCollection, type CollectionEntry } from 'astro:content';
import VenueTopPage from '../../components/VenueTopPage.astro';

/**
 * /venues/[slug] — one page per entry in the `sites` collection.
 * Adding templates/ace-factory/content/sites/<slug>.json auto-produces a page.
 */
export async function getStaticPaths() {
  const sites = await getCollection('sites');
  return sites.map((site) => ({
    params: { slug: site.id },
    props: { site },
  }));
}

interface Props {
  site: CollectionEntry<'sites'>;
}
const { site } = Astro.props as Props;
---
<VenueTopPage data={site.data} />
