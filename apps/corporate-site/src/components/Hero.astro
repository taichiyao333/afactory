---
import TemplateImage from '../lib/TemplateImage.astro';

/**
 * Hero — full-bleed interior photograph with either a venue logo or
 * a Cormorant wordmark centred bottom-third.
 */
export interface Props {
  variant: 'logo' | 'text';
  image: string;
  subtitle: string;
  title?: string;
  logo?: string | null;
  logoMaxHeight?: number;
}

const {
  variant,
  image,
  subtitle,
  title = 'Ace Factory',
  logo,
  logoMaxHeight = 120,
} = Astro.props;
---
<section class="hero">
  <div class="hero__bg">
    <TemplateImage src={image} alt="" loading="eager" fetchpriority="high" />
  </div>
  <div class="hero__veil" aria-hidden="true"></div>
  <div class="hero__content">
    {variant === 'logo' && logo ? (
      <div class="hero__logo-wrap" style={`--logo-max-h: ${logoMaxHeight}px`}>
        <TemplateImage src={logo} alt={title} loading="eager" />
      </div>
    ) : (
      <div class="hero__title">{title}</div>
    )}
    {subtitle && <div class="hero__subtitle">{subtitle}</div>}
  </div>
  <div class="hero__scroll" aria-hidden="true">Scroll</div>
</section>

<style>
  .hero {
    position: relative;
    height: 100vh;
    min-height: 640px;
    background: var(--af-bg);
    overflow: hidden;
  }
  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero__bg :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
  .hero__veil {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(180deg, rgba(0, 0, 0, 0.2) 0%, rgba(0, 0, 0, 0.55) 100%);
  }
  .hero__content {
    position: absolute;
    left: 0; right: 0;
    bottom: 96px;
    z-index: 2;
    text-align: center;
    color: var(--af-fg);
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .hero__logo-wrap { display: contents; }
  .hero__logo-wrap :global(img) {
    max-height: var(--logo-max-h, 120px);
    max-width: 72%;
    width: auto;
    height: auto;
    opacity: 0.96;
  }
  .hero__title {
    font-family: var(--af-font-display);
    font-weight: 400;
    font-size: var(--af-fs-display-xl);
    letter-spacing: 0.04em;
    line-height: 1;
  }
  .hero__subtitle {
    font-family: var(--af-font-jp-serif);
    font-size: var(--af-fs-body-md);
    color: var(--af-fg-muted);
    letter-spacing: 0.22em;
    margin-top: 24px;
  }
  .hero__scroll {
    position: absolute;
    left: 50%;
    bottom: 28px;
    transform: translateX(-50%);
    z-index: 2;
    color: var(--af-fg-muted);
    font-family: var(--af-font-display);
    font-size: 12px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
  }
</style>
