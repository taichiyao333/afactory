---
/**
 * Nav — fixed top nav. Transparent over hero, adds backdrop past 80px scroll.
 */
export interface Props {
  items: { en: string; jp: string; href: string }[];
}
const { items } = Astro.props;
---
<nav class="site-nav" id="site-nav">
  <div class="site-nav__brand">ACE&nbsp;FACTORY</div>
  <div class="site-nav__links">
    {items.map((item) => (
      <a href={item.href} class="site-nav__link">{item.en}</a>
    ))}
  </div>
</nav>

<script>
  const nav = document.getElementById('site-nav');
  if (nav) {
    const update = () => {
      nav.classList.toggle('is-scrolled', window.scrollY > 80);
    };
    window.addEventListener('scroll', update, { passive: true });
    update();
  }
</script>

<style>
  .site-nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    height: 72px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 var(--af-pad-x-desktop);
    background: transparent;
    transition:
      background var(--af-dur-base) var(--af-ease),
      backdrop-filter var(--af-dur-base) var(--af-ease);
    z-index: var(--af-z-nav);
    color: var(--af-fg);
  }
  .site-nav.is-scrolled {
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }
  .site-nav__brand {
    font-family: var(--af-font-display);
    font-size: 20px;
    letter-spacing: 0.12em;
  }
  .site-nav__links {
    display: flex;
    gap: 36px;
  }
  .site-nav__link {
    color: var(--af-fg);
    text-decoration: none;
    font-family: var(--af-font-display);
    font-size: 14px;
    letter-spacing: 0.08em;
  }
</style>
