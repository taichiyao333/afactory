---
/**
 * SectionHeading — two-tier heading pattern (EN display over JP sub).
 *
 * Ported 1:1 from templates/ace-factory/ui_kits/corporate-site/SectionHeading.jsx.
 * Inline styles replaced with tokenised scoped CSS.
 *
 * @example
 *   <SectionHeading en="Our Philosophy" jp="私たちの理念" />
 *   <SectionHeading en="Access" jp="店舗アクセス" align="left" />
 */
export interface Props {
  en?: string;
  jp?: string;
  align?: 'center' | 'left';
}

const { en = 'Section', jp = '', align = 'center' } = Astro.props;
---
<div class="section-heading" data-align={align}>
  <div class="section-heading__en">{en}</div>
  {jp && <div class="section-heading__jp">{jp}</div>}
</div>

<style>
  .section-heading {
    margin-bottom: 56px;
  }
  .section-heading[data-align='center'] { text-align: center; }
  .section-heading[data-align='left']   { text-align: left; }

  .section-heading__en {
    font-family: var(--af-font-display);
    font-weight: 400;
    font-size: var(--af-fs-display-lg);
    line-height: 1.1;
    letter-spacing: var(--af-ls-display);
    color: var(--af-fg);
  }

  .section-heading__jp {
    font-family: var(--af-font-jp-serif);
    font-weight: 400;
    font-size: var(--af-fs-body-md);
    letter-spacing: var(--af-ls-heading);
    color: var(--af-fg-muted);
    margin-top: 16px;
  }
</style>
