---
import TemplateImage from '../lib/TemplateImage.astro';

/**
 * VenueCard — one venue tile used in ServiceSection's ALL VENUES grid.
 */
export interface Props {
  name: string;
  url: string;
  logo: string | null;
  interior: string;
}
const { name, url, logo, interior } = Astro.props;
---
<a href={url} target="_blank" rel="noreferrer" class="venue-card">
  <div class="venue-card__media">
    <TemplateImage src={interior} alt={name} />
    <div class="venue-card__veil" aria-hidden="true"></div>
    <div class="venue-card__overlay">
      {logo ? (
        <div class="venue-card__logo-wrap">
          <TemplateImage src={logo} alt={name} />
        </div>
      ) : (
        <div class="venue-card__wordmark">{name}</div>
      )}
    </div>
  </div>
  <div class="venue-card__caption">{name}</div>
</a>

<style>
  .venue-card {
    display: block;
    text-decoration: none;
    color: inherit;
  }
  .venue-card__media {
    position: relative;
    aspect-ratio: 4 / 3;
    background: #111;
    overflow: hidden;
  }
  .venue-card__media :global(img) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .venue-card__veil {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.45);
    transition: background var(--af-dur-base) var(--af-ease);
  }
  .venue-card:hover .venue-card__veil { background: rgba(0, 0, 0, 0.25); }
  .venue-card__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .venue-card__logo-wrap :global(img) {
    max-height: 56px;
    max-width: 60%;
    width: auto;
    height: auto;
    opacity: 0.95;
  }
  .venue-card__wordmark {
    font-family: var(--af-font-display);
    font-size: var(--af-fs-display-sm);
    letter-spacing: 0.08em;
    color: var(--af-fg);
  }
  .venue-card__caption {
    padding-top: 16px;
    text-align: center;
    font-family: var(--af-font-display);
    font-size: 18px;
    letter-spacing: 0.1em;
    color: var(--af-fg);
  }
</style>
